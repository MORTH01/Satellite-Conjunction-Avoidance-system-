# ─── Space-Track.org credentials ─────────────────────────────────────────────
# Your login from space-track.org (the only API you need)
SPACETRACK_USER=your_email@example.com
SPACETRACK_PASS=your_password_here

# ─── App secret (any random string is fine for local dev) ────────────────────
SECRET_KEY=my-local-secret-key-123

# ─── These are set automatically by start.sh — do NOT change ─────────────────
# DATABASE_URL=postgresql+asyncpg://localhost/conjunction_db
# REDIS_URL=redis://localhost:6379/0
